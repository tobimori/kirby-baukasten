{
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "mprocs",
		"dev:kirby": "env-cmd --use-shell \"PHP_CLI_SERVER_WORKERS=4 php -S \\$KIRBY_DEV_HOSTNAME:\\$KIRBY_DEV_PORT -t public vendor/getkirby/cms/router.php\"",
		"dev:vite": "vite",
		"dev:plugin": "cd site/plugins/extended && kirbyup serve src/index.js",
		"build": "pnpm run \"/build:/\"",
		"build:site": "vite build",
		"build:plugin": "cd site/plugins/extended && kirbyup src/index.js",
		"types": "kirby types:create --force && tsc --noEmit",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"fmt": "oxfmt .",
		"fmt:check": "oxfmt --check ."
	},
	"dependencies": {
		"@alpinejs/focus": "^3.15.8",
		"@alpinejs/intersect": "^3.15.8",
		"alpinejs": "^3.15.8",
		"htmx.org": "^2.0.8",
		"idiomorph": "^0.7.4",
		"unlazy": "^1.1.0"
	},
	"devDependencies": {
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "4.2.1",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/alpinejs": "^3.13.11",
		"@types/alpinejs__focus": "^3.13.4",
		"@types/alpinejs__intersect": "^3.13.4",
		"@types/node": "^25.3.5",
		"browserslist": "^4.28.1",
		"env-cmd": "^11.0.0",
		"kirbyup": "^3.4.1",
		"laravel-vite-plugin": "^2.1.0",
		"lightningcss": "^1.31.1",
		"mprocs": "^0.8.3",
		"oxfmt": "^0.36.0",
		"oxlint": "^1.51.0",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite": "npm:rolldown-vite@^7.3.1",
		"vite-plugin-compression2": "^2.5.0",
		"vite-plugin-devtools-json": "^1.0.0",
		"vite-svg-sprite-wrapper": "^1.5.0"
	},
	"browserslist": [
		"last 2 versions",
		">= 0.4%",
		"not dead",
		"Firefox ESR",
		"not op_mini all",
		"not and_uc > 0"
	],
	"packageManager": "pnpm@10.28.2",
	"pnpm": {
		"overrides": {
			"vite": "npm:rolldown-vite@latest"
		},
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"esbuild"
		]
	}
}
